{
  "openapi": "3.0.3",
  "info": {
    "title": "GoJohnny API",
    "description": "Consultoria pessoal de corrida com IA. Fase 1: identificacao de sessao, feature flags, contexto persistente e protecao contra sobrescrita de plano.",
    "version": "1.1.0"
  },
  "servers": [
    {
      "url": "https://gojohnny.onrender.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyHeader": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "AtletaCreate": {
        "type": "object",
        "required": [
          "nome",
          "apelido"
        ],
        "properties": {
          "nome": {
            "type": "string"
          },
          "apelido": {
            "type": "string"
          },
          "objetivo": {
            "type": "string"
          },
          "nivel": {
            "type": "string"
          },
          "dias_treino": {
            "type": "integer"
          },
          "altura_cm": {
            "type": "integer"
          },
          "peso_kg": {
            "type": "number"
          },
          "pace_confortavel": {
            "type": "string"
          },
          "maior_distancia_recente_km": {
            "type": "number"
          },
          "historico_dores": {
            "type": "string"
          },
          "tenis_disponiveis": {
            "type": "string"
          },
          "proxima_prova": {
            "type": "string"
          },
          "data_proxima_prova": {
            "type": "string",
            "format": "date"
          },
          "distancia_alvo_km": {
            "type": "number"
          },
          "observacoes": {
            "type": "string"
          }
        }
      },
      "Atleta": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "nome": {
            "type": "string"
          },
          "apelido": {
            "type": "string"
          },
          "objetivo": {
            "type": "string"
          },
          "nivel": {
            "type": "string"
          },
          "dias_treino": {
            "type": "integer"
          },
          "altura_cm": {
            "type": "integer"
          },
          "peso_kg": {
            "type": "number"
          },
          "pace_confortavel": {
            "type": "string"
          },
          "maior_distancia_recente_km": {
            "type": "number"
          },
          "historico_dores": {
            "type": "string"
          },
          "tenis_disponiveis": {
            "type": "string"
          },
          "proxima_prova": {
            "type": "string"
          },
          "data_proxima_prova": {
            "type": "string",
            "format": "date"
          },
          "distancia_alvo_km": {
            "type": "number"
          },
          "observacoes": {
            "type": "string"
          },
          "criado_em": {
            "type": "string",
            "format": "date-time"
          },
          "atualizado_em": {
            "type": "string",
            "format": "date-time"
          },
          "usar_datas_reais": {
            "type": "boolean"
          },
          "usar_contexto_atleta": {
            "type": "boolean"
          },
          "usar_google_calendar": {
            "type": "boolean"
          },
          "usar_strava": {
            "type": "boolean"
          }
        }
      },
      "AtletaUpdate": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "apelido": {
            "type": "string"
          },
          "objetivo": {
            "type": "string"
          },
          "nivel": {
            "type": "string"
          },
          "dias_treino": {
            "type": "integer"
          },
          "altura_cm": {
            "type": "integer"
          },
          "peso_kg": {
            "type": "number"
          },
          "pace_confortavel": {
            "type": "string"
          },
          "maior_distancia_recente_km": {
            "type": "number"
          },
          "historico_dores": {
            "type": "string"
          },
          "tenis_disponiveis": {
            "type": "string"
          },
          "proxima_prova": {
            "type": "string"
          },
          "data_proxima_prova": {
            "type": "string",
            "format": "date"
          },
          "distancia_alvo_km": {
            "type": "number"
          },
          "observacoes": {
            "type": "string"
          }
        }
      },
      "CheckinCreate": {
        "type": "object",
        "required": [
          "apelido",
          "semana_inicio"
        ],
        "properties": {
          "apelido": {
            "type": "string"
          },
          "semana_inicio": {
            "type": "string",
            "format": "date"
          },
          "treinos_planejados": {
            "type": "integer"
          },
          "treinos_realizados": {
            "type": "integer"
          },
          "volume_planejado_km": {
            "type": "number"
          },
          "volume_realizado_km": {
            "type": "number"
          },
          "pace_medio": {
            "type": "string"
          },
          "cansaco_0_10": {
            "type": "integer"
          },
          "dores": {
            "type": "string"
          },
          "sono": {
            "type": "string"
          },
          "sensacao_geral": {
            "type": "string"
          },
          "observacoes": {
            "type": "string"
          }
        }
      },
      "Checkin": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "atleta_id": {
            "type": "string",
            "format": "uuid"
          },
          "semana_inicio": {
            "type": "string",
            "format": "date"
          },
          "treinos_planejados": {
            "type": "integer"
          },
          "treinos_realizados": {
            "type": "integer"
          },
          "volume_planejado_km": {
            "type": "number"
          },
          "volume_realizado_km": {
            "type": "number"
          },
          "pace_medio": {
            "type": "string"
          },
          "cansaco_0_10": {
            "type": "integer"
          },
          "dores": {
            "type": "string"
          },
          "sono": {
            "type": "string"
          },
          "sensacao_geral": {
            "type": "string"
          },
          "observacoes": {
            "type": "string"
          },
          "criado_em": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PlanoSemanalCreate": {
        "type": "object",
        "required": [
          "apelido",
          "semana_inicio"
        ],
        "properties": {
          "apelido": {
            "type": "string"
          },
          "semana_inicio": {
            "type": "string",
            "format": "date"
          },
          "objetivo_semana": {
            "type": "string"
          },
          "volume_planejado_km": {
            "type": "number"
          },
          "status": {
            "type": "string"
          },
          "plano": {
            "type": "object"
          },
          "data_inicio": {
            "type": "string",
            "format": "date"
          },
          "data_prova": {
            "type": "string",
            "format": "date"
          },
          "dias_treino_json": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "versao_estrutura": {
            "type": "integer"
          },
          "novo_ciclo": {
            "type": "boolean",
            "default": false,
            "description": "Se ja existe plano ativo para este atleta, exige true para criar um novo (que arquivara o anterior). Sem este flag, o backend retorna 409 Conflict."
          }
        }
      },
      "PlanoSemanal": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "atleta_id": {
            "type": "string",
            "format": "uuid"
          },
          "semana_inicio": {
            "type": "string",
            "format": "date"
          },
          "objetivo_semana": {
            "type": "string"
          },
          "volume_planejado_km": {
            "type": "number"
          },
          "status": {
            "type": "string"
          },
          "plano": {
            "type": "object"
          },
          "criado_em": {
            "type": "string",
            "format": "date-time"
          },
          "atualizado_em": {
            "type": "string",
            "format": "date-time"
          },
          "data_inicio": {
            "type": "string",
            "format": "date"
          },
          "data_prova": {
            "type": "string",
            "format": "date"
          },
          "dias_treino_json": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "versao_estrutura": {
            "type": "integer"
          }
        }
      },
      "SessaoIniciarRequest": {
        "type": "object",
        "required": [
          "apelido"
        ],
        "properties": {
          "apelido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Apelido informado pelo usuario no inicio do chat."
          }
        }
      },
      "FlagsResponse": {
        "type": "object",
        "properties": {
          "usar_datas_reais": {
            "type": "boolean"
          },
          "usar_contexto_atleta": {
            "type": "boolean"
          },
          "usar_google_calendar": {
            "type": "boolean"
          },
          "usar_strava": {
            "type": "boolean"
          }
        }
      },
      "SessaoIniciarResponse": {
        "type": "object",
        "required": [
          "status",
          "flags",
          "instrucao_continuacao"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "novo",
              "existente"
            ]
          },
          "atleta": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Atleta"
              },
              {
                "type": "null"
              }
            ]
          },
          "plano_atual": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PlanoSemanal"
              },
              {
                "type": "null"
              }
            ]
          },
          "contexto_resumo": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "flags": {
            "$ref": "#/components/schemas/FlagsResponse"
          },
          "instrucao_continuacao": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/atletas": {
      "post": {
        "summary": "Criar novo atleta",
        "operationId": "create_atleta",
        "tags": [
          "atletas"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AtletaCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Atleta criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Atleta"
                }
              }
            }
          },
          "409": {
            "description": "Apelido já existe"
          },
          "401": {
            "description": "Não autorizado - API key inválida"
          }
        }
      }
    },
    "/atletas/{apelido}": {
      "get": {
        "summary": "Buscar atleta por apelido",
        "operationId": "get_atleta",
        "tags": [
          "atletas"
        ],
        "parameters": [
          {
            "name": "apelido",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Atleta encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Atleta"
                }
              }
            }
          },
          "404": {
            "description": "Atleta não encontrado"
          },
          "401": {
            "description": "Não autorizado - API key inválida"
          }
        }
      },
      "patch": {
        "summary": "Atualizar atleta",
        "operationId": "update_atleta",
        "tags": [
          "atletas"
        ],
        "parameters": [
          {
            "name": "apelido",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AtletaUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Atleta atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Atleta"
                }
              }
            }
          },
          "404": {
            "description": "Atleta não encontrado"
          },
          "401": {
            "description": "Não autorizado - API key inválida"
          }
        }
      }
    },
    "/checkins": {
      "post": {
        "summary": "Criar check-in semanal",
        "operationId": "create_checkin",
        "tags": [
          "checkins"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckinCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Check-in criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Checkin"
                }
              }
            }
          },
          "404": {
            "description": "Atleta não encontrado"
          },
          "401": {
            "description": "Não autorizado - API key inválida"
          }
        }
      }
    },
    "/checkins/{apelido}": {
      "get": {
        "summary": "Listar check-ins do atleta",
        "operationId": "list_checkins",
        "tags": [
          "checkins"
        ],
        "parameters": [
          {
            "name": "apelido",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de check-ins",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Checkin"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Atleta não encontrado"
          },
          "401": {
            "description": "Não autorizado - API key inválida"
          }
        }
      }
    },
    "/planos-semanais": {
      "post": {
        "summary": "Criar plano semanal",
        "operationId": "create_plano",
        "tags": [
          "planos_semanais"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlanoSemanalCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Plano semanal criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlanoSemanal"
                }
              }
            }
          },
          "404": {
            "description": "Atleta não encontrado"
          },
          "401": {
            "description": "Não autorizado - API key inválida"
          },
          "409": {
            "description": "Plano ativo ja existe. Para sobrescrever, refazer com novo_ciclo: true."
          }
        }
      }
    },
    "/planos-semanais/{apelido}/atual": {
      "get": {
        "summary": "Obter plano semanal ativo atual",
        "operationId": "get_plano_atual",
        "tags": [
          "planos_semanais"
        ],
        "parameters": [
          {
            "name": "apelido",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plano semanal ativo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlanoSemanal"
                }
              }
            }
          },
          "404": {
            "description": "Plano semanal não encontrado ou atleta não existe"
          },
          "401": {
            "description": "Não autorizado - API key inválida"
          }
        }
      }
    },
    "/sessao/iniciar": {
      "post": {
        "summary": "Iniciar sessao do atleta",
        "operationId": "iniciar_sessao",
        "tags": [
          "sessao"
        ],
        "description": "Identifica usuario por apelido. Retorna status (novo|existente), plano atual, contexto e instrucao de continuacao para o GPT. Idempotente. NAO cria atleta - criacao continua via POST /atletas. DEVE ser o PRIMEIRO endpoint chamado em qualquer chat novo.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessaoIniciarRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sessao iniciada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessaoIniciarResponse"
                }
              }
            }
          },
          "401": {
            "description": "Nao autorizado - API key invalida"
          }
        }
      }
    }
  }
}