{
  "openapi": "3.0.3",
  "info": {
    "title": "GoJohnny API",
    "description": "Consultoria pessoal de corrida com IA",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://gojohnny.onrender.com",
      "description": "Production server"
    }
